@page
@model ASPPresentacion_Productos_JP.Pages.Ventanas.TiendasModel
@{
    ViewData["Title"] = "Tiendas";
}

@if (ViewData["Mensaje"] != null)
{
    <div class="alert alert-danger">@ViewData["Mensaje"]</div>
}

<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Tiendas</h3>
            </div>

            <div>
                <input type="submit" value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                @if (Model.Tienda == null)
                {
                    <input type="submit" value="Nuevo"
                           class="btn btn-secondary"
                           asp-page-handler="BtNuevo" />
                }
                else
                {
                    <input type="submit" value="Guardar"
                           class="btn btn-secondary"
                           asp-page-handler="BtGuardar" />
                }
            </div>

            @if (Model.Tienda != null)
            {
                <input type="hidden" asp-for="@Model.Tienda!.Id" />
                <div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <input class="form-control" asp-for="@Model.Tienda!.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Direccion</label>
                        <input class="form-control" asp-for="@Model.Tienda!.Direccion" />
                    </div>
                    <div class="form-group">
                        <label>Activo</label>
                        <input asp-for="@Model.Tienda!.Activo" />
                    </div>
                    <div class="form-group">
                        <label>Fecha de Fundación</label>
                        <input class="form-control" asp-for="@Model.Tienda!.FechaFundacion" />
                    </div>
                </div>
            }

            @if (Model.Tienda != null && Model.Borrando)
            {
                <div class="popup">
                    <div>
                        <h2>Mensaje</h2>
                        <h6>¿Desea borrar el studio @Model.Tienda!.Nombre?</h6>
                        <input type="submit" value="Cerrar"
                               asp-page-handler="BtCerrar"
                               class="btn btn-secondary" />
                        <input type="submit" value="Borrar"
                               asp-page-handler="BtBorrar"
                               class="btn btn-secondary" />
                    </div>
                </div>
            }

            @if (Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="table table-striped table-bordered table-hover">
                    <tr>
                        <th>Nombre</th>
                        <th>Direccion</th>
                        <th>Activo</th>
                        <th>FechaFundacion</th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Nombre</td>
                            <td>@elemento.Direccion</td>
                            <td>@elemento.Activo</td>
                            <td>@elemento.FechaFundacion</td>
                            <td>
                                <input type="submit" value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>