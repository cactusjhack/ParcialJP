@page
@model ASPPresentacion_Productos_JP.Pages.Ventanas.ProductosModel
@{
    ViewData["Title"] = "Productos";
}

@if (ViewData["Mensaje"] != null)
{
    <div class="alert alert-danger">@ViewData["Mensaje"]</div>
}

<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Productos</h3>
            </div>

            <div>
                <input type="submit" value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                @if (Model.Producto == null)
                {
                    <input type="submit" value="Nuevo"
                           class="btn btn-secondary"
                           asp-page-handler="BtNuevo" />
                }
                else
                {
                    <input type="submit" value="Guardar"
                           class="btn btn-secondary"
                           asp-page-handler="BtGuardar" />
                }
            </div>

            @if (Model.Producto != null)
            {

                @if (Model.Producto.Id != 0)
                {
                    <input type="hidden" asp-for="@Model.Producto!.Id" />
                }

                <div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <input class="form-control" asp-for="@Model.Producto!.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Codigo</label>
                        <input class="form-control" asp-for="@Model.Producto!.Codigo" />
                    </div>
                    <div class="form-group">
                        <label>Stock</label>
                        <input class="form-control" asp-for="@Model.Producto!.Stock" />
                    </div>
                    <div class="form-group">
                        <label>Tienda</label>
                        <input class="form-control" asp-for="@Model.Producto!.Tienda" />
                    </div>
                </div>
            }

            @if (Model.Producto != null && Model.Borrando)
            {
                <div class="popup">
                    <div>
                        <h2>Mensaje</h2>
                        <h6>¿Desea borrar la serie @Model.Producto!.Nombre?</h6>
                        <input type="submit" value="Cerrar"
                               asp-page-handler="BtCerrar"
                               class="btn btn-secondary" />
                        <input type="submit" value="Borrar"
                               asp-page-handler="BtBorrar"
                               class="btn btn-secondary" />
                    </div>
                </div>
            }

            @if (Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="table table-striped table-bordered table-hover">
                    <tr>
                        <th>Nombre</th>
                        <th>Codigo</th>
                        <th>Stock</th>
                        <th>Tienda</th>
                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Nombre</td>
                            <td>@elemento.Codigo</td>
                            <td>@elemento.Stock</td>
                            <td>@elemento.Tienda</td>
                            <td>
                                <input type="submit" value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>